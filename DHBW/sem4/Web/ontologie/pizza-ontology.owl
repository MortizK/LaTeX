<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/pizza#"
     xml:base="http://example.org/pizza"
     xmlns:ex="http://example.org/pizza#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/pizza"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/pizza#belegtMit -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza#belegtMit">
        <rdfs:domain rdf:resource="http://example.org/pizza#Pizza"/>
        <rdfs:range rdf:resource="http://example.org/pizza#Belag"/>
    </owl:ObjectProperty>


    <!-- http://example.org/pizza#zutat -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza#zutat">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/pizza#belag"/>
            <rdf:Description rdf:about="http://example.org/pizza#zutat"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>


    <!-- http://example.org/pizza#belag -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza#belag">
        <rdfs:subPropertyOf rdf:resource="http://example.org/pizza#zutat"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/pizza#Artischocke -->

    <owl:Class rdf:about="http://example.org/pizza#Artischocke">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza#Gemuese"/>
    </owl:Class>
    


    <!-- http://example.org/pizza#Belag -->

    <owl:Class rdf:about="http://example.org/pizza#Belag"/>
    


    <!-- http://example.org/pizza#Gemuese -->

    <owl:Class rdf:about="http://example.org/pizza#Gemuese">
        <owl:disjointWith rdf:resource="http://example.org/pizza#Wurst"/>
    </owl:Class>
    


    <!-- http://example.org/pizza#Käse -->

    <owl:Class rdf:about="http://example.org/pizza#Käse"/>
    


    <!-- http://example.org/pizza#Lebensmittel -->

    <owl:Class rdf:about="http://example.org/pizza#Lebensmittel"/>
    


    <!-- http://example.org/pizza#Margherita -->

    <owl:Class rdf:about="http://example.org/pizza#Margherita">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza#Pizza"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:complementOf>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.org/pizza#belegtMit"/>
                        <owl:someValuesFrom rdf:resource="http://example.org/pizza#Wurst"/>
                    </owl:Restriction>
                </owl:complementOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza#belegtMit"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza#Käse"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza#belegtMit"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza#Tomate"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/pizza#Pizza -->

    <owl:Class rdf:about="http://example.org/pizza#Pizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza#Lebensmittel"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza#belegtMit"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">8</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/pizza#Belag"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/pizza#QuattroStagioni -->

    <owl:Class rdf:about="http://example.org/pizza#QuattroStagioni">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza#Pizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza#belegtMit"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza#Artischocke"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza#belegtMit"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">4</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/pizza#Belag"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/pizza#Tomate -->

    <owl:Class rdf:about="http://example.org/pizza#Tomate">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza#Belag"/>
        <rdfs:subClassOf rdf:resource="http://example.org/pizza#Gemuese"/>
    </owl:Class>
    


    <!-- http://example.org/pizza#Wurst -->

    <owl:Class rdf:about="http://example.org/pizza#Wurst">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza#Belag"/>
        <rdfs:subClassOf rdf:resource="http://example.org/pizza#Lebensmittel"/>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/pizza#Salami -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza#Salami">
        <rdf:type rdf:resource="http://example.org/pizza#Wurst"/>
    </owl:NamedIndividual>
</rdf:RDF>



